{
	"name": "n8n-nodes-nx3",
	"version": "0.3.0",
	"description": "n8n community node to read, create and modify Sage X3 objects via the CAdxWebServiceXmlCC SOAP service (JSON in, JSON out)",
	"license": "MIT",
	"homepage": "https://github.com/adrien-ge/n8n-nodes-nx3#readme",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"sage",
		"sage-x3",
		"x3",
		"erp",
		"soap",
		"adonix",
		"syracuse"
	],
	"author": {
		"name": "Adrien Geraldes",
		"email": "adrien.geraldes@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/adrien-ge/n8n-nodes-nx3.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/Nx3SoapApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Nx3Soap/Nx3Soap.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.9.6",
		"release-it": "20.2.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
